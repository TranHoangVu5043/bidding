<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane fx:id="contentArea" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="550.0" prefWidth="850.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="AdminController">
   <left>
      <AnchorPane prefWidth="170.0" style="-fx-background-color: #2D3E50;" BorderPane.alignment="CENTER">
         <children>
            <VBox fx:id="sideMenu" alignment="TOP_CENTER" spacing="25.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
               <children>
                  <ImageView fx:id="imgAvatar" fitHeight="50.0" fitWidth="50.0" pickOnBounds="true" preserveRatio="true">
                     <VBox.margin>
                        <Insets top="20.0" />
                     </VBox.margin>
                  </ImageView>
                  <Label text="ADMINISTRATOR" textFill="WHITE">
                     <font>
                        <Font name="System Bold" size="11.0" />
                     </font>
                  </Label>
                  <Separator maxWidth="130.0" opacity="0.2">
                     <VBox.margin>
                        <Insets bottom="5.0" top="5.0" />
                     </VBox.margin>
                  </Separator>

                  <Button fx:id="btnDashboard" onAction="#showDashboard" prefHeight="28.0" prefWidth="145.0" style="-fx-background-radius: 4;" text="Dashboard">
                     <font><Font size="10.5" /></font>
                  </Button>
                  <Button fx:id="btnSeller" onAction="#showSeller" prefHeight="28.0" prefWidth="145.0" style="-fx-background-radius: 4;" text="Sellers" />
                  <Button fx:id="btnUser" onAction="#showUser" prefHeight="28.0" prefWidth="145.0" style="-fx-background-radius: 4;" text="Users" />
                  <Button fx:id="btnRevenue" onAction="#showRevenue" prefHeight="28.0" prefWidth="145.0" style="-fx-background-radius: 4;" text="Revenue" />
                  <Button fx:id="btnNotification" onAction="#showNotifications" prefHeight="28.0" prefWidth="145.0" style="-fx-background-radius: 4;" text="Notifications" />
                  <Button fx:id="btnHistory" onAction="#showHistory" prefHeight="28.0" prefWidth="145.0" style="-fx-background-radius: 4;" text="History" />
                  <Button fx:id="btnSetting" onAction="#showSetting" prefHeight="28.0" prefWidth="145.0" style="-fx-background-radius: 4;" text="Settings" />

                  <VBox VBox.vgrow="ALWAYS" />
               </children>
            </VBox>
         </children>
      </AnchorPane>
   </left>
   <center>
      <VBox alignment="TOP_CENTER" spacing="12.0" style="-fx-background-color: #F4F7F6;" BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
         </padding>
         <children>
            <HBox alignment="CENTER_LEFT">
               <children>
                  <VBox maxWidth="160.0" prefHeight="65.0" prefWidth="160.0" style="-fx-background-color: white; -fx-background-radius: 5; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 5, 0, 0, 2);">
                     <children>
                        <Label text="Total Revenue" textFill="#7f8c8d">
                           <font><Font size="10.0" /></font>
                           <VBox.margin><Insets left="12.0" top="12.0" /></VBox.margin>
                        </Label>
                        <Label fx:id="lblTotalRevenue" text="\$1,337,000" textFill="#2c3e50">
                           <font><Font name="System Bold" size="18.0" /></font>
                           <VBox.margin><Insets left="12.0" /></VBox.margin>
                        </Label>
                     </children>
                  </VBox>
               </children>
            </HBox>

            <HBox alignment="CENTER" spacing="12.0" VBox.vgrow="ALWAYS">
               <children>
                  <VBox style="-fx-background-color: white; -fx-background-radius: 5;" HBox.hgrow="ALWAYS">
                     <children>
                        <LineChart fx:id="chartRevenueTrend" prefHeight="200.0" title="Revenue Trend">
                           <xAxis><CategoryAxis side="BOTTOM" /></xAxis>
                           <yAxis><NumberAxis side="LEFT" /></yAxis>
                        </LineChart>
                     </children>
                  </VBox>
                  <VBox style="-fx-background-color: white; -fx-background-radius: 5;">
                     <children>
                        <PieChart fx:id="chartSeller" prefHeight="200.0" prefWidth="220.0" title="Sellers" />
                     </children>
                  </VBox>
               </children>
            </HBox>

            <VBox style="-fx-background-color: white; -fx-background-radius: 5;">
               <children>
                  <TableView fx:id="tableRecentPlatform" prefHeight="159.0" prefWidth="646.0">
                     <columns>
                        <TableColumn fx:id="colUser" prefWidth="120.0" text="User" />
                        <TableColumn fx:id="colActivity" prefWidth="300.0" text="Activity" />
                        <TableColumn fx:id="colStatus" prefWidth="100.0" text="Status" />
                     </columns>
                     <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
